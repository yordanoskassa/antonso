PORT=3005
# Browser origin (JWT issuer / audience; cookie host when using Vite proxy)
BETTER_AUTH_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
# Optional: comma-separated extra origins (e.g. https://tryanton.xyz,https://www.tryanton.xyz)
# BETTER_AUTH_TRUSTED_ORIGINS=
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
MONGODB_URI=mongodb://127.0.0.1:27017/anton_portal
# Multi-document user+account writes use transactions only when true. Required: MongoDB replica set.
# Standalone/local MongoDB must leave this unset or false, or OAuth signup can fail with unable_to_create_user.
# MONGODB_USE_TRANSACTIONS=true

# Google OAuth (Web client) — redirect URI must be {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
